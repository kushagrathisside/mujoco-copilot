# ── Ollama (default, no key needed) ──────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
# Fallbacks for the UI Settings -> Ollama (local) controls
OLLAMA_TIMEOUT_SECONDS=300
OLLAMA_NUM_PREDICT=8192

# ── Activity log (downloadable support/debug log) ────────────────────────────
# ACTION_LOG_DIR=/absolute/path/to/mujoco-copilot/logs
# ACTION_LOG_INCLUDE_CONTENT=false
# ACTION_LOG_MAX_CONTENT_CHARS=2000

# ── Cloud provider keys (optional, can also be entered in the UI) ─────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AIza...
# GROQ_API_KEY=gsk_...
